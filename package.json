    "@unpic/react": "^1.0.2",
    "@vitejs/plugin-react": "5.0.4",
    "ipx": "^3.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5",
    "vite": "6.4.3"
  }
}
