{
  "name": "wardrobe",
  "version": "1.0.0",
  "private": true,
  "description": "A local-first AI wardrobe gallery powered by OpenAI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "personal": "npm run build && vite preview --host 127.0.0.1 --port 4173 --strictPort",
